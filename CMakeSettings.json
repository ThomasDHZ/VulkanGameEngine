{
  "version": "0.2.1",
  "configurations": [
    {
      "name": "Windows-Debug",
      "project": "CMakeLists.txt",
      "projectTarget": "VulkanGameEngine",
      "type": "default",
      "cwd": "${debugInfo.defaultWorkingDirectory}\\bin\\Assets",
      "environment": []
    },
    {
      "name": "Linux-Debug",
      "project": "CMakeLists.txt",
      "projectTarget": "VulkanGameEngine",
      "type": "remote",
      "remoteMachineName": "${defaultRemoteMachineName}",
      "program": "${debugInfo.fullTargetPath}",
      "args": [],
      "cwd": "${debugInfo.defaultWorkingDirectory}/bin/Assets",
      "environment": [
        {
          "name": "VK_INSTANCE_LAYERS",
          "value": ""
        },
        {
          "name": "VK_LAYER_PATH",
          "value": ""
        }
      ]
    }
  ]
}